<script>
function copyLink() {
	var input = document.getElementById("link-only");
	input.select();
	input.setSelectionRange(0, 99999);
	navigator.clipboard.writeText(input.value).then(function() {
		alert("Посилання скопійовано!");
	}, function(err) {
		alert("Помилка копіювання: " + err);
	});
}
</script>
