<script language="JavaScript">
//<!--
function enable_submit () {
	if ($(':input[type=submit]').prop('disabled')) {
		$(':input[type=submit]').prop('disabled', false);
		$('#form_pic').removeClass('fa-spinner fa-pulse').addClass('fa-download');
	}
}
function disable_submit () {
	$(':input[type=submit]').prop('disabled', true);
	$('#form_pic').removeClass('fa-download').addClass('fa-spinner fa-pulse');
	setTimeout(function(){
		enable_submit();
	}, 5000);
}
$(document).ready(function(){
	$("input[name=format]").click(function (event) {
		$('form[name=save]').attr('action', $(this).data('url'));
		enable_submit();
	});

	$('form[name=save]').submit(function( event ){
		if ($(this).find('input[name="nospam"]').length) {
			$(this).find('input[name="nospam"]').val(getCookie('sid'));
		}
		disable_submit();
		return true;
	});
});
//-->
</script>
